# Core naming
LDAP_DOMAIN=example.org
LDAP_BASE_DN=dc=example,dc=org
LDAP_ORGANISATION=Example Inc.

# Admin
LDAP_ADMIN_USERNAME=admin
LDAP_ADMIN_PASSWORD=change-me

# Listener
LDAP_ENABLE_LDAP=true
LDAP_ENABLE_LDAPS=false
LDAP_PORT_NUMBER=389
LDAP_LDAPS_PORT_NUMBER=636

# Logging
LDAP_LOG_LEVEL=256
LDAP_DEBUG_LEVEL=256

# TLS
LDAP_ENABLE_TLS=false
LDAP_REQUIRE_TLS=false
LDAP_TLS_CERT_FILE=/etc/openldap/certs/tls.crt
LDAP_TLS_KEY_FILE=/etc/openldap/certs/tls.key
LDAP_TLS_CA_FILE=/etc/openldap/certs/ca.crt
LDAP_TLS_DH_PARAM_FILE=
LDAP_TLS_VERIFY_CLIENT=never
LDAP_SIMPLE_BIND_MIN_SSF=128

# Database
LDAP_MDB_MAXSIZE=1073741824
LDAP_MDB_CHECKPOINT=1024 5
LDAP_MDB_DBNOSYNC=false

# Default tree
LDAP_SKIP_DEFAULT_TREE=false
LDAP_CREATE_ADMIN_ENTRY=true
LDAP_CREATE_PEOPLE_OU=true
LDAP_CREATE_GROUPS_OU=true
LDAP_PEOPLE_OU=people
LDAP_GROUPS_OU=groups

# Schemas and modules
LDAP_EXTRA_SCHEMAS=cosine inetorgperson nis
LDAP_LOAD_MODULES=

# Optional overlays
LDAP_ENABLE_MEMBEROF=false
LDAP_ENABLE_REFINT=false
LDAP_ENABLE_SYNCPROV=false
LDAP_SYNCPROV_CHECKPOINT=100 10
LDAP_SYNCPROV_SESSIONLOG=
LDAP_ENABLE_ACCESSLOG=false
LDAP_ACCESSLOG_SUFFIX=cn=accesslog
LDAP_ACCESSLOG_LOGOPS=writes
LDAP_ACCESSLOG_LOGPURGE=07+00:00 01+00:00

# Advanced config extension points
LDAP_CONFIG_BACKEND=slapd.conf
LDAP_CONFIG_DIR=/etc/openldap/slapd.d
LDAP_LDAPI_URI=ldapi://%2Fvar%2Frun%2Fopenldap%2Fldapi
LDAP_SKIP_DEFAULT_CONFIG=false
LDAP_CUSTOM_SCHEMA_DIR=/etc/openldap/custom-schema
LDAP_CUSTOM_PRECONFIG_DIR=/etc/openldap/custom-config/pre
LDAP_CUSTOM_POSTCONFIG_DIR=/etc/openldap/custom-config/post
LDAP_INITDB_DIR=/docker-entrypoint-initdb.d
